# Copy this file to .env.local or .env.production and fill in real values.
AIMITRA_ENVIRONMENT=Local
API_KEY=
OPENAI_URL=
OPENAI_MODEL=
DB_PROVIDER=
DB_CONNECTION_STRING=
PRESIDIO_ENDPOINT=
AIMITRA_KERNEL_PLUGIN_ASSEMBLIES= // semicolon separated list of plugin DLLs or folders containing plugin DLLs, e.g. .\Aimitra.SamplePlugins\bin\Debug\net6.0;.\AnotherPluginFolder\bin\Debug\net6.0
